# Generated by go2rpm 1.5.0
%bcond_without check

# https://github.com/prometheus/prom2json
%global goipath         github.com/prometheus/prom2json
Version:                1.3.0
%global commit          90766c07ebcf5c37149a843ea74f873a6842475f

%gometa

%global common_description %{expand:
A tool to scrape a Prometheus client and dump the result as JSON.}

%global golicenses      LICENSE NOTICE
%global godocs          CHANGELOG.md CODE_OF_CONDUCT.md CONTRIBUTING.md\\\
                        MAINTAINERS.md README.md SECURITY.md

Name:           %{goname}
Release:        %autorelease
Summary:        A tool to scrape a Prometheus client and dump the result as JSON

# Upstream license specification: Apache-2.0
License:        ASL 2.0
URL:            %{gourl}
Source0:        %{gosource}
# prometheus/common doesn't implement log anymore
Patch0:         0001-Patch-to-remove-prometheus-common-log.patch

BuildRequires:  golang(github.com/matttproud/golang_protobuf_extensions/pbutil)
BuildRequires:  golang(github.com/prometheus/client_model/go)
BuildRequires:  golang(github.com/prometheus/common/expfmt)

%if %{with check}
# Tests
BuildRequires:  golang(github.com/davecgh/go-spew/spew)
%endif

%description
%{common_description}

%gopkg

%prep
%goprep
%patch0 -p1

%build
for cmd in cmd/* ; do
  %gobuild -o %{gobuilddir}/bin/$(basename $cmd) %{goipath}/$cmd
done

%install
%gopkginstall
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files
%license LICENSE NOTICE
%doc CHANGELOG.md CODE_OF_CONDUCT.md CONTRIBUTING.md MAINTAINERS.md README.md
%doc SECURITY.md
%{_bindir}/*

%gopkgfiles

%changelog
%autochangelog
