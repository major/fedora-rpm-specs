#     c.Assert(err, ErrorMatches, `io: read/write on closed pipe`)
# ... value = nil
# ... regex string = "io: read/write on closed pipe"
# ... Error value is nil
# OOPS: 55 passed, 1 FAILED
%gocheck -d .
%endif

%gopkgfiles

