# Generated by go2rpm 1.2
%bcond_without check

# https://github.com/liamg/gitjacker
%global goipath         github.com/liamg/gitjacker
Version:                0.0.2

%gometa

%global common_description %{expand:
Leak git repositories from misconfigured websites.}

%global golicenses      LICENSE
%global godocs          README.md

Name:           gitjacker
Release:        10%{?dist}
Summary:        Leak git repositories from misconfigured websites

License:        Unlicense
URL:            %{gourl}
Source0:        %{gosource}

BuildRequires:  golang(github.com/liamg/tml)
BuildRequires:  golang(github.com/sirupsen/logrus)
BuildRequires:  golang(github.com/spf13/cobra)

Requires:       git-core

%if %{with check}
# Tests
BuildRequires:  golang(github.com/magiconair/properties/assert)
BuildRequires:  git-core
%endif

%description
%{common_description}

%gopkg

%prep
%goprep

%build
for cmd in cmd/* ; do
  %gobuild -o %{gobuilddir}/bin/$(basename $cmd) %{goipath}/$cmd
done

%install
%gopkginstall
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files
%license LICENSE
%doc README.md
%{_bindir}/*

%gopkgfiles

