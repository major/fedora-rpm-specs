%global commit          7cb4b85ec19c7c220ab71433a230f7eb200d639d

%gometa

%global common_description %{expand:
Retrieve password from user terminal or piped input without echo.}

%global golicenses      LICENSE.txt OPENSOLARIS.LICENSE
%global godocs          README.md

%global gosupfiles      glide.lock glide.yaml

Name:           %{goname}
Version:        0
Release:        %autorelease -p
Summary:        Getpasswd for Go

# Upstream license specification: ISC and CDDL-1.0
License:        ISC and CDDL-1.0
URL:            %{gourl}
Source0:        %{gosource}
Source1:        glide.yaml
Source2:        glide.lock
# Fix "+build comment must appear before package clause" error
Patch0:         0001-Fix-build-comment-clause.patch

BuildRequires:  golang(golang.org/x/crypto/ssh/terminal)

%description
%{common_description}

%gopkg

%prep
%goprep
%patch0 -p1
cp %{S:1} %{S:2} .

%install
%gopkginstall

%if %{with check}
%check
%gocheck
%endif

%gopkgfiles

%changelog
