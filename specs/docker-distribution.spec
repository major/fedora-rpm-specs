%pre
# check /var/lib/registry owned by user other than 'registry'
if [ $1 -gt 1 ] ; then
  if [[ -d %{_sharedstatedir}/registry ]] && \
     [[ $(stat -c '%U' %{_sharedstatedir}/registry) != "registry" ]] ; then
    mkdir -p %{_localstatedir}/lib/rpm-state/docker-distribution
    touch %{_localstatedir}/lib/rpm-state/docker-distribution/owner
