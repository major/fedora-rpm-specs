Name:           perl-Getopt-Yath
Version:        2.000011
Release:        1%{?dist}
Summary:        Option processing in yath style
License:        GPL-1.0-or-later OR Artistic-1.0-Perl
URL:            https://metacpan.org/dist/Getopt-Yath
Source0:        https://www.cpan.org/authors/id/E/EX/EXODIST/Getopt-Yath-%{version}.tar.gz
BuildArch:      noarch
BuildRequires:  coreutils
BuildRequires:  make
BuildRequires:  perl-generators
BuildRequires:  perl-interpreter
BuildRequires:  perl(:VERSION) >= 5.12.0
BuildRequires:  perl(ExtUtils::MakeMaker) >= 6.76
BuildRequires:  perl(strict)
BuildRequires:  perl(warnings)
# Run-time:
BuildRequires:  perl(Carp)
# Class::XSAccessor 1.19 is not a dependency, it only selects a workaround.
BuildRequires:  perl(Cpanel::JSON::XS)
BuildRequires:  perl(File::Temp)
BuildRequires:  perl(Importer) >= 0.024
BuildRequires:  perl(parent)
# Term::Table::Util version from Term::Table in META
BuildRequires:  perl(Term::Table::Util) >= 0.028
# Optional run-time:
BuildRequires:  perl(Term::ANSIColor)
# Tests:
BuildRequires:  perl(base)
BuildRequires:  perl(parent)
BuildRequires:  perl(Test2::V0) >= 0.000097
BuildRequires:  perl(Test::More)
Requires:       perl(Importer) >= 0.024
Recommends:     perl(Term::ANSIColor)
Requires:       perl(Term::Table::Util) >= 0.028

# Remove under-specified dependencies
%global __requires_exclude %{?__requires_exclude:%{__requires_exclude}|}^perl\\((Importer|Term::Table::Util|Test2::V0)\\)$
# Hide private modules
%global __requires_exclude %{__requires_exclude}|^perl\\(Object::HashBase::Test::HBase

%description
This is the getopt processor yath (Yet Another Test Harness) uses.

%package tests
Summary:        Tests for %{name}
Requires:       %{name} = %{?epoch:%{epoch}:}%{version}-%{release}
Requires:       perl-Test-Harness
Requires:       perl(Test2::V0) >= 0.000097

%description tests
Tests from %{name}. Execute them
with "%{_libexecdir}/%{name}/test".

%prep
%setup -q -n Getopt-Yath-%{version}

%build
perl Makefile.PL INSTALLDIRS=vendor NO_PACKLIST=1 NO_PERLLOCAL=1
%{make_build}

%install
%{make_install}
# Install tests
mkdir -p %{buildroot}%{_libexecdir}/%{name}
cp -a t %{buildroot}%{_libexecdir}/%{name}
cat > %{buildroot}%{_libexecdir}/%{name}/test << 'EOF'
#!/bin/sh
cd %{_libexecdir}/%{name} && exec prove -I . -j "$(getconf _NPROCESSORS_ONLN)"
EOF
chmod +x %{buildroot}%{_libexecdir}/%{name}/test

%check
export HARNESS_OPTIONS=j$(perl -e 'if ($ARGV[0] =~ /.*-j([0-9][0-9]*).*/) {print $1} else {print 1}' -- '%{?_smp_mflags}')
make test

%files
%license LICENSE
# README.md is redundant
%doc Changes README
%dir %{perl_vendorlib}/Getopt
%{perl_vendorlib}/Getopt/Yath
%{perl_vendorlib}/Getopt/Yath.pm
%{_mandir}/man3/Getopt::Yath.*
%{_mandir}/man3/Getopt::Yath::*

%files tests
%{_libexecdir}/%{name}

