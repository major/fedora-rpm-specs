# Generated by go2rpm 1.8.2
%bcond_without check

# https://github.com/microcosm-cc/bluemonday
%global goipath         github.com/microcosm-cc/bluemonday
Version:                1.0.21

%gometa

%global common_description %{expand:
bluemonday is a fast golang HTML sanitizer (inspired by the OWASP Java HTML
Sanitizer) to scrub user generated content of XSS.}

%global golicenses      LICENSE.md
%global godocs          CONTRIBUTING.md SECURITY.md README.md CREDITS.md

Name:           %{goname}
Release:        %autorelease
Summary:        Fast golang HTML sanitizer

License:        BSD-3-Clause
URL:            %{gourl}
Source:         %{gosource}

%description %{common_description}

%gopkg

%prep
%goprep

%generate_buildrequires
%go_generate_buildrequires

%build
for cmd in cmd/* ; do
  %gobuild -o %{gobuilddir}/bin/$(basename $cmd) %{goipath}/$cmd
done

%install
%gopkginstall
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files
%license LICENSE.md
%doc CONTRIBUTING.md SECURITY.md README.md CREDITS.md
%{_bindir}/*

%gopkgfiles

%changelog
%autochangelog
