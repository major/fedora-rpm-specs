# Generated by go2rpm 1.9.0
%bcond_without check
%global debug_package %{nil}

# https://github.com/zclconf/go-cty
%global goipath         github.com/zclconf/go-cty
Version:                1.13.2

%gometa

%global common_description %{expand:
A type system for dynamic values in Go applications.}

%global golicenses      LICENSE
%global godocs          docs CHANGELOG.md COMPATIBILITY.md README.md

Name:           %{goname}
Release:        %autorelease
Summary:        A type system for dynamic values in Go applications

License:        MIT
URL:            %{gourl}
Source:         %{gosource}

%description %{common_description}

%gopkg

%prep
%goprep
%autopatch -p1

%generate_buildrequires
%go_generate_buildrequires

%install
%gopkginstall

%if %{with check}
%check
# cty/function/stdlib fails on 32 bits arches
%ifarch %{ix86}
%gocheck -d cty/function/stdlib
%else
# TestFormatDate fails with golang-1.20 https://github.com/zclconf/go-cty/issues/147
for test in "TestFormatDate" \
; do
awk -i inplace '/^func.*'"$test"'\(/ { print; print "\tt.Skip(\"disabled failing test\")"; next}1' $(grep -rl $test)
done
%gocheck
%endif
%endif

%gopkgfiles

%changelog
%autochangelog
