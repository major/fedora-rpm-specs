# Generated by go2rpm 1
%bcond_without check

# https://github.com/mileusna/useragent
%global goipath         github.com/mileusna/useragent
Version:                1.0.2

%gometa

%global common_description %{expand:
Package ua.Parse(userAgent string) function parses browser's and bot's user
agents strings and determines:

 - User agent name and version (Chrome, Firefox, Googlebot, etc.)
 - Operating system name and version (Windows, Android, iOS etc.)
 - Device type (mobile, desktop, tablet, bot)
 - Device name if available (iPhone, iPad, Huawei VNS-L21)
 - URL provided by the bot (http://www.google.com/bot.html etc.)}

%global golicenses      LICENSE
%global godocs          README.md

Name:           %{goname}
Release:        6%{?dist}
Summary:        Go parser for user agent strings

License:        MIT
URL:            %{gourl}
Source0:        %{gosource}

%description
%{common_description}

%gopkg

%prep
%goprep

%install
%gopkginstall

%if %{with check}
%check
%gocheck
%endif

%gopkgfiles

