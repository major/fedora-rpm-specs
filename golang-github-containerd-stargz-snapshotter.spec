%description
%{common_description}

%gopkg

%prep
%goprep
%autopatch -p1

# Remove ipfs module. It's not needed by any of this package's dependents,
# and it brings in extra, unpackaged dependencies.
rm -rfv ipfs/

# Remove binaries that are already provided by stargz-snapshotter and bring in
# extra dependencies.
rm -rfv cmd/

%install
%gopkginstall

%if %{with check}
%check
# Requires network
# estargz/zstdchunked, metadata/db: OOM on i686
%gocheck -t nativeconverter -d estargz/zstdchunked -d metadata/db
