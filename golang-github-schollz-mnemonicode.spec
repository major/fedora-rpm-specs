# Generated by go2rpm 1.3
%bcond_without check

# https://github.com/schollz/mnemonicode
%global goipath         github.com/schollz/mnemonicode
Version:                1.0.1

%gometa

%global common_description %{expand:
Mnemonicode is a method for encoding binary data into a sequence of words which
can be spoken over the phone, for example, and converted back to data on the
other side.}

%global golicenses      LICENCE
%global godocs          README.md

Name:           %{goname}
Release:        %autorelease
Summary:        Method for encoding binary data into a sequence of words

License:        MIT
URL:            %{gourl}
Source0:        %{gosource}

BuildRequires:  golang(golang.org/x/text/transform)

%description
%{common_description}

%package -n     mnemonicode
Summary:        %{summary}
License:        MIT and BSD

%description -n mnemonicode
%{common_description}

%gopkg

%prep
%goprep

%build
for cmd in cmd/* ; do
  %gobuild -o %{gobuilddir}/bin/$(basename $cmd) %{goipath}/$cmd
done

%install
%gopkginstall
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files -n mnemonicode
%license LICENCE
%doc README.md
%{_bindir}/*

%gopkgfiles

%changelog
%autochangelog
