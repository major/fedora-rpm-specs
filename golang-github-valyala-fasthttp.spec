# Generated by go2rpm 1
%global debug_package %{nil}
# Checks require a network connection
%bcond_with check

# https://github.com/valyala/fasthttp
%global goipath         github.com/valyala/fasthttp
Version:                1.29.0

%gometa

%global common_description %{expand:
Fast HTTP package for Go. Tuned for high performance. Zero memory allocations
in hot paths. Up to 10x faster than net/http.}

%global golicenses      LICENSE LICENSE-reuseport
%global godocs          examples README.md TODO SECURITY.md README-prefork.md

Name:           %{goname}
Release:        5%{?dist}
Summary:        Fast HTTP package

# reuseport is also MIT
License:        MIT
URL:            %{gourl}
Source0:        %{gosource}

BuildRequires:  golang(github.com/andybalholm/brotli)
BuildRequires:  golang(github.com/klauspost/compress/flate)
BuildRequires:  golang(github.com/klauspost/compress/gzip)
BuildRequires:  golang(github.com/klauspost/compress/zlib)
BuildRequires:  golang(github.com/valyala/bytebufferpool)
BuildRequires:  golang(github.com/valyala/tcplisten)
BuildRequires:  golang(golang.org/x/crypto/acme)
BuildRequires:  golang(golang.org/x/crypto/acme/autocert)
BuildRequires:  golang(golang.org/x/net/http/httpproxy)
BuildRequires:  golang(golang.org/x/net/proxy)

%description
%{common_description}

%gopkg

%prep
%goprep
mv reuseport/LICENSE LICENSE-reuseport
mv prefork/README.md README-prefork.md

%build
%gobuild -o %{gobuilddir}/bin/fasthttp %{goipath}

%install
%gopkginstall
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files
%license LICENSE LICENSE-reuseport
%doc examples README.md TODO SECURITY.md README-prefork.md
%{_bindir}/*

%gopkgfiles

